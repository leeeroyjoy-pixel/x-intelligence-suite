{
  "profile": {
    "name": "jav-news",
    "platform": "x",
    "timezone": "Asia/Shanghai"
  },
  "sources": {
    "source_file": "../../../sources/example-handles.md",
    "source_type": "markdown_list",
    "source_groups": [],
    "include_handles": [],
    "exclude_handles": [],
    "dedupe_sources": true,
    "priority_handles": [
      "example_handle_one",
      "example_handle_two",
      "example_handle_three",
      "example_handle_four",
      "example_handle_five",
      "example_handle_six"
    ]
  },
  "window": {
    "mode": "yesterday",
    "content_date": null,
    "window_start": null,
    "window_end": null,
    "output_date_mode": "run_date"
  },
  "selection": {
    "max_items": 6,
    "max_items_per_source": 2,
    "selection_mode": "scored",
    "prefer_media_posts": true,
    "prefer_original_posts": true,
    "drop_replies": true,
    "drop_retweets": true,
    "drop_duplicate_topics": true,
    "priority_keywords": [
      "新作",
      "解禁",
      "デビュー",
      "先行配信",
      "イベント",
      "無料",
      "特典",
      "開催",
      "終了",
      "発売"
    ],
    "exclude_keywords": []
  },
  "media": {
    "download_media": true,
    "embed_images": true,
    "embed_videos": false,
    "max_embedded_images_per_item": 8,
    "count_video_in_media_count": false,
    "media_dir_name": "tweet_screens",
    "media_naming_mode": "handle_tweetid"
  },
  "output": {
    "output_root": "../../../outputs/jav-news",
    "output_subdir_pattern": "{run_date}",
    "report_filename_pattern": "X-日本成人资讯账号昨日汇总-{content_date}-真实版.md",
    "write_markdown": true,
    "write_summary_json": true,
    "write_media_manifest": true,
    "write_distribution_summary": true,
    "distribution_summary_filename": "distribution-summary.txt",
    "title_template": "X 日本成人资讯账号昨日汇总｜{content_date}（真实版）",
    "markdown_template": "default_report_template.md"
  },
  "publish": {
    "publish_enabled": false,
    "require_artifacts_before_publish": true,
    "require_summary_success": true,
    "fail_if_main_doc_missing": true,
    "dry_run": true,
    "emit_stdout_summary": true
  }
}
